<nav class="navbar" aria-label="Navegación principal">
  <div class="container nav-inner">
    <a class="brand" href="/" aria-label="Inicio Luis Miraglio">
      <span class="brand-name">Luis Miraglio</span>
      <span class="brand-role">Full-Stack Developer</span>
    </a>

    <button
      class="nav-toggle"
      aria-label="Abrir menú"
      aria-controls="navLinks"
      aria-expanded="false"
      id="navToggle"
      type="button"
    >
      <span class="hamburger"></span>
    </button>

    <div class="nav-links" id="navLinks">
      <a class="nav-link" href="#proyectos">Proyectos</a>
      <a class="nav-link" href="#experiencia">Experiencia</a>
      <a class="nav-link" href="#skills">Skills</a>
      <a class="nav-link" href="#sobre-mi">Sobre mí</a>
      <a class="nav-link" href="#cv">CV</a>
      <a class="nav-link" href="#certificaciones">Certificaciones</a>
      <a class="nav-link nav-link--cta" href="#contacto">Contacto</a>
    </div>
  </div>
</nav>

<script is:inline>
  function closeMenuIfMobile() {
    const navLinks = document.getElementById('navLinks');
    const navToggle = document.getElementById('navToggle');

    if (navLinks) navLinks.classList.remove('open');
    if (navToggle) {
      navToggle.classList.remove('active');
      navToggle.setAttribute('aria-expanded', 'false');
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const navToggle = document.getElementById('navToggle');
    const navLinks = document.getElementById('navLinks');

    closeMenuIfMobile();

    if (navToggle && navLinks) {
      navToggle.addEventListener('click', () => {
        const isOpen = navLinks.classList.toggle('open');
        navToggle.classList.toggle('active', isOpen);
        navToggle.setAttribute('aria-expanded', String(isOpen));
      });
    }

    if (navLinks) {
      navLinks.querySelectorAll('.nav-link').forEach((link) => {
        link.addEventListener('click', () => {
          closeMenuIfMobile();
        });
      });
    }

    window.addEventListener('resize', () => {
      if (window.innerWidth > 760) {
        if (navLinks) navLinks.classList.remove('open');
        if (navToggle) {
          navToggle.classList.remove('active');
          navToggle.setAttribute('aria-expanded', 'false');
        }
      }
    });
  });
</script>
