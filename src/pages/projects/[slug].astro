---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} | Portfolio`}>
  <Navbar />

  <main class="section">
    <div class="container">
      <a href="/#proyectos" class="back-link">← Volver</a>

      <header class="project-header">
        <div class="badge">{project.data.category}</div>
        <h1 class="project-title">{project.data.title}</h1>
        <p class="project-desc">{project.data.description}</p>

        {project.data.highlight && (
          <p class="project-highlight">⭐ {project.data.highlight}</p>
        )}

        <div class="tags">
          {project.data.tags.map((t) => (
            <span>{t}</span>
          ))}
        </div>

        <div class="links">
          {project.data.repo && (
            <a class="btn ghost" href={project.data.repo} target="_blank" rel="noreferrer">GitHub</a>
          )}
          {project.data.demo && (
            <a class="btn ghost" href={project.data.demo} target="_blank" rel="noreferrer">Demo</a>
          )}
          {project.data.video && (
            <a class="btn ghost" href={project.data.video} target="_blank" rel="noreferrer">Video</a>
          )}
        </div>
      </header>

      <article class="md">
        <Content />
      </article>
    </div>
  </main>
</BaseLayout>
