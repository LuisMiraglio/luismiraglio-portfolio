---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const {
  title,
  description,
  category,
  status,
  repo,
  image,
  highlight,
  tags = [],
  relatedTitle,
  relatedSlug,
  relatedLabel,
  playStore,
} = project.data;

const repoUrl = repo;
const isProduction = status === "production";
---

<BaseLayout title={`${title} | Portfolio`}>
  <Navbar />

  <main class="project-page">
    <div class="container">
      <a href="/#proyectos" class="back-link">Volver a proyectos</a>

      <section class="project-hero">
        {image && (
          <div class="project-hero-image">
            <img src={image} alt={title} />
          </div>
        )}

        <div class="project-hero-content">
          <div class="project-meta">
            {category && <span class="detail-badge">{category}</span>}

            {isProduction && (
              <span class="detail-badge detail-badge--status">
                <span class="status-dot"></span>
                En producción
              </span>
            )}

            {repoUrl && (
              <a
                href={repoUrl}
                class="detail-badge detail-badge--repo"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Ver repositorio de ${title} en GitHub`}
              >
                <svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16" fill="currentColor">
                  <path d="M12 2C6.48 2 2 6.58 2 12.22c0 4.5 2.87 8.32 6.84 9.67.5.1.66-.22.66-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.21-3.37-1.21-.46-1.2-1.11-1.52-1.11-1.52-.91-.64.07-.63.07-.63 1 .07 1.53 1.05 1.53 1.05.9 1.57 2.35 1.12 2.92.85.09-.67.35-1.12.63-1.38-2.22-.26-4.55-1.14-4.55-5.08 0-1.12.39-2.03 1.03-2.74-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0 1 12 6.84c.85 0 1.71.12 2.51.35 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.71 1.03 1.62 1.03 2.74 0 3.95-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.8 0 .27.18.6.67.49A10.23 10.23 0 0 0 22 12.22C22 6.58 17.52 2 12 2z"></path>
                </svg>
                GitHub
              </a>
            )}

            {playStore && (
              <a
                href={playStore}
                class="detail-badge detail-badge--store"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Ver ${title} en Play Store`}
              >
                Play Store
              </a>
            )}
          </div>

          <h1 class="project-title">{title}</h1>

          {description && <p class="project-description">{description}</p>}

          {highlight && (
            <div class="project-highlight">
              <strong>Impacto</strong>
              <p>{highlight}</p>
            </div>
          )}

          {tags.length > 0 && (
            <div class="project-tags">
              {tags.map((tag) => <span class="project-tag">{tag}</span>)}
            </div>
          )}
        </div>
      </section>

      <article class="project-content md">
        <Content />
      </article>

      {relatedSlug && relatedTitle && (
        <section class="related-project">
          <span class="related-project-label">
            {relatedLabel || "Proyecto relacionado"}
          </span>

          <div class="related-project-card">
            <div>
              <h3>{relatedTitle}</h3>
              <p>
                Este proyecto forma parte del mismo ecosistema y complementa la solución
                implementada en producción.
              </p>
            </div>

            <a href={`/projects/${relatedSlug}`} class="btn ghost">
              Ver proyecto
            </a>
          </div>
        </section>
      )}
    </div>
  </main>
</BaseLayout>