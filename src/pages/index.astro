---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const certs = await getCollection("certs");

const featuredCerts = certs.filter((c) => c.data.featured);
const otherCerts = certs.filter((c) => !c.data.featured);

// Categorías únicas para filtros (solo "otras" certs)
const certCategories = Array.from(new Set(otherCerts.map((c) => c.data.category))).sort();
---

<BaseLayout>
  <Navbar />

<main id="contenido" class="hero">
  <div class="container">
<h1 class="hero-title reveal-words" aria-label="Full-Stack Developer & Network Systems Specialist">
  <span>Full-Stack</span>
  <span>Developer</span>
  <span class="break"><br /></span>
  <span>&</span>
  <span>Network</span>
  <span>Systems</span>
  <span>Specialist</span>
</h1>

    <p class="subtitle">
      Diseño y desarrollo soluciones End-to-End: desde el relevamiento de requerimientos y la arquitectura,
      hasta el backend, frontend, infraestructura y despliegue en producción.
      Integro software e infraestructura para crear sistemas sólidos, escalables y eficientes.
    </p>

<div class="hero-metrics">
  <div class="metric">
    <span class="metric-value">+90%</span>
    <span class="metric-label">Reducción de tiempos</span>
  </div>

  <div class="metric">
    <span class="metric-value">+5 proyectos activos</span>
    <span class="metric-label">Implementados en producción</span>
  </div>

  <div class="metric">
    <span class="metric-value">Full Stack</span>
    <span class="metric-label">Desarrollo End-to-End</span>
  </div>

  <div class="metric">
    <span class="metric-value">Infra + Code</span>
    <span class="metric-label">Perfil híbrido</span>
  </div>
</div>

    <div class="cta">
      <a href="#proyectos" class="btn primary">Ver proyectos</a>
      <a href="#contacto" class="btn ghost">Contactar</a>
    </div>
  </div>
</main>

<!-- ================= PROYECTOS ================= -->

<section id="proyectos" class="section">
  <div class="container">
    <h2>Proyectos</h2>
    <p class="section-subtitle">
      Una selección de proyectos reales enfocados en automatización, web y herramientas internas.
    </p>

    <div class="projects-grid">
      {projects.map((p) => (
        <div class="project-card">
          
          <!-- Link invisible al detalle -->
          <a class="card-link" href={`/projects/${p.slug}`} aria-label="Ver detalle"></a>

          <!-- Imagen del proyecto -->
          {p.data.image && (
            <div class="project-image">
              <img
                src={p.data.image}
                alt={p.data.title}
                loading="lazy"
              />
            </div>
          )}

          <div class="project-meta">
            <div class="card-category">{p.data.category}</div>

            {p.data.status === "production" && (
              <div class="status-badge">
                <span class="status-dot"></span>
                En producción
              </div>
            )}

            {p.data.repo && (
              <a
                class="repo-badge"
                href={p.data.repo}
                target="_blank"
                rel="noreferrer"
                aria-label="Ver repositorio en GitHub"
              >
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                  <path
                    fill="currentColor"
                    d="M12 .5C5.73.5.75 5.67.75 12.1c0 5.14 3.28 9.5 7.83 11.04.57.11.78-.25.78-.56v-2.04c-3.19.71-3.86-1.58-3.86-1.58-.52-1.36-1.27-1.72-1.27-1.72-1.04-.73.08-.72.08-.72 1.15.08 1.75 1.2 1.75 1.2 1.02 1.78 2.67 1.26 3.32.96.1-.76.4-1.26.73-1.55-2.55-.3-5.23-1.31-5.23-5.84 0-1.29.44-2.35 1.17-3.18-.12-.3-.51-1.52.11-3.17 0 0 .96-.32 3.14 1.21.91-.26 1.88-.39 2.85-.39.97 0 1.95.13 2.85.39 2.18-1.53 3.14-1.21 3.14-1.21.62 1.65.23 2.87.11 3.17.73.83 1.17 1.89 1.17 3.18 0 4.54-2.68 5.54-5.24 5.83.41.36.78 1.08.78 2.18v3.24c0 .31.21.67.79.56 4.55-1.54 7.82-5.9 7.82-11.04C23.25 5.67 18.27.5 12 .5z"
                  />
                </svg>
                GitHub
              </a>
            )}
          </div>

          <h3>{p.data.title}</h3>
          <p>{p.data.description}</p>

          {p.data.highlight && (
            <p class="card-highlight">⭐ {p.data.highlight}</p>
          )}

          <div class="tags">
            {p.data.tags.map((t) => (
              <span>{t}</span>
            ))}
          </div>

        </div>
      ))}
    </div>
  </div>
</section>


  <!-- ================= EXPERIENCIA PROFESIONAL ================= -->

<section id="experiencia" class="section">
  <div class="container">
    <h2>Experiencia Profesional</h2>
    <p class="section-subtitle">
      Desarrollo de soluciones tecnológicas aplicadas en entornos reales de producción.
    </p>

    <div class="experience-card">
      <div class="experience-header">
        <div class="experience-year">
          2024 - Actualidad
        </div>

        <div>
          <h3>Conectar SRL</h3>
          <p class="experience-role">
            Full-Stack Developer & Técnico en Redes Informáticas
          </p>
        </div>
      </div>

      <ul class="experience-list">
        <li>Lidero el ciclo de vida completo de desarrollo (End-to-End) para aplicaciones web, móviles y herramientas de automatización.</li>
        <li>Relevamiento de requerimientos, diseño de arquitectura, desarrollo backend/frontend y despliegue en servidores Windows/Linux.</li>
        <li>Desarrollo de APIs REST con Python (FastAPI, Django, Flask) y .NET, integradas con SQL Server y PostgreSQL.</li>
        <li>Automatización de procesos técnicos con Python y Selenium, reduciendo errores humanos en un 90%.</li>
        <li>Desarrollo y publicación de aplicación móvil en Flutter en Google Play Store (AAB, testing cerrado y políticas).</li>
        <li>Mantenimiento evolutivo y soporte de infraestructura de software, asegurando estabilidad operativa.</li>
      </ul>

      <div class="tags">
        <span>Python</span>
        <span>FastAPI</span>
        <span>Flutter</span>
        <span>SQL Server</span>
        <span>Selenium</span>
        <span>Networking</span>
      </div>
    </div>
  </div>
</section>

<!-- ================= SKILLS (Engineering layout) ================= -->

<section id="skills" class="section">
  <div class="container">
    <h2>Skills</h2>
    <p class="section-subtitle">
      Stack técnico organizado por áreas. Enfocado en desarrollo End-to-End, automatización e infraestructura.
    </p>

    <div class="skills-stack">
      <!-- Backend -->
      <div class="skill-group skill-backend">
        <h3 class="skill-title">Backend</h3>
        <div class="skill-rule"></div>
        <p class="skill-items">
          <span>Python</span><span>FastAPI</span><span>Django</span><span>Flask</span><span>.NET</span><span>JWT</span>
        </p>
      </div>

      <!-- Frontend -->
      <div class="skill-group skill-frontend">
        <h3 class="skill-title">Frontend</h3>
        <div class="skill-rule"></div>
        <p class="skill-items">
          <span>HTML</span><span>CSS</span><span>JavaScript</span><span>Astro</span><span>Bootstrap</span>
        </p>
      </div>

      <!-- Mobile -->
      <div class="skill-group skill-mobile">
        <h3 class="skill-title">Mobile</h3>
        <div class="skill-rule"></div>
        <p class="skill-items">
          <span>Flutter</span><span>Dart</span><span>Google Play</span><span>AAB</span>
        </p>
      </div>

      <!-- Bases de datos -->
      <div class="skill-group skill-db">
        <h3 class="skill-title">Bases de datos</h3>
        <div class="skill-rule"></div>
        <p class="skill-items">
          <span>SQL Server</span><span>PostgreSQL</span><span>SQLite</span><span>SQL</span>
        </p>
      </div>

      <!-- Automatización -->
      <div class="skill-group skill-auto">
        <h3 class="skill-title">Automatización</h3>
        <div class="skill-rule"></div>
        <p class="skill-items">
          <span>Selenium</span><span>Web Scraping</span><span>Scripts</span><span>CLI</span>
        </p>
      </div>

      <!-- DevOps & Infra -->
      <div class="skill-group skill-devops">
        <h3 class="skill-title">DevOps & Infra</h3>
        <div class="skill-rule"></div>
        <p class="skill-items">
          <span>Git</span><span>GitHub</span><span>Docker</span><span>Linux</span><span>Windows Server</span><span>Networking</span><span>FTTH</span>
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ================= SOBRE MI ================= -->

<section id="sobre-mi" class="section">
  <div class="container">
    <h2>Sobre mí</h2>
    <p class="section-subtitle">
      Perfil híbrido que integra desarrollo de software con infraestructura y automatización.
    </p>

    <div class="about-grid">
      <!-- Columna izquierda -->
      <div class="about-main">
        <div class="about-highlight">
          <strong>Full-Stack + Redes</strong> — construyo soluciones End-to-End y automatizo procesos en entornos reales de producción.
        </div>

        <p>
          Mi enfoque no es convencional. Vengo del mundo de la infraestructura de redes y evolucioné hacia el desarrollo Full-Stack,
          lo que me permite entender cómo se conectan los sistemas desde la base hasta la experiencia final del usuario.
        </p>

        <p>
          Trabajo diseñando soluciones End-to-End: arquitectura, backend, frontend, automatización,
          despliegue y optimización operativa.
        </p>
      </div>

      <!-- Columna derecha -->
      <div class="about-points">
        <div class="about-item">
          <h3>Visión integral</h3>
          <p>Comprendo tanto el código como la infraestructura que lo sostiene.</p>
        </div>

        <div class="about-item">
          <h3>Enfoque en eficiencia</h3>
          <p>Automatizo procesos para reducir errores y optimizar tiempos operativos.</p>
        </div>

        <div class="about-item">
          <h3>Entornos reales</h3>
          <p>Desarrollo soluciones que funcionan en producción, no solo en laboratorio.</p>
        </div>

        <div class="about-item">
          <h3>Aprendizaje continuo</h3>
          <p>Me mantengo actualizado en backend, mobile, DevOps y automatización.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ================= CV ================= -->

<section id="cv" class="section">
  <div class="container">
    <h2>Currículum</h2>
    <p class="section-subtitle">
      Descargá mi CV en PDF o abrilo online.
    </p>

    <div class="cv-card">
      <div>
        <h3 class="cv-title">Luis Miraglio — Full-Stack Developer & Redes</h3>
        <p class="cv-text">
          Perfil técnico orientado a soluciones End-to-End, automatización y despliegue en producción.
        </p>

        <div class="cv-actions">
          <a class="btn primary" href="/cv/Luis-Miraglio-CV.pdf" download>
            Descargar CV
          </a>

          <a class="btn ghost" href="/cv/Luis-Miraglio-CV.pdf" target="_blank" rel="noreferrer">
            Ver online
          </a>
        </div>

        <p class="cv-note">
          Última actualización: <span class="cv-date">2026</span>
        </p>
      </div>

      <div class="cv-meta">
        <div class="cv-meta-row">
          <span class="cv-label">Formato</span>
          <span class="cv-value">PDF</span>
        </div>
        <div class="cv-meta-row">
          <span class="cv-label">Idioma</span>
          <span class="cv-value">Español</span>
        </div>
        <div class="cv-meta-row">
          <span class="cv-label">Enfoque</span>
          <span class="cv-value">Full-Stack • Automation • Networking</span>
        </div>
      </div>
    </div>
  </div>
</section>

  <!-- ================= CERTIFICACIONES DESTACADAS ================= -->

  <section id="certificaciones" class="section">
    <div class="container">
      <h2>Certificaciones Destacadas</h2>
      <p class="section-subtitle">
        Certificaciones seleccionadas por relevancia para mi perfil Full-Stack.
      </p>

      <div class="projects-grid">
        {featuredCerts.map((c) => (
          <div class="project-card">
            <div class="cert-label">Certificado</div>

            {c.data.credentialUrl && (
              <a
                class="card-link"
                href={c.data.credentialUrl}
                target="_blank"
                rel="noreferrer"
                aria-label="Ver certificado"
              ></a>
            )}

            <div class="card-category">{c.data.category}</div>

            <h3>{c.data.title}</h3>
            <p>{c.data.issuer} • {c.data.date}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= TODAS LAS CERTIFICACIONES (CON FILTROS) ================= -->

  <section id="todas-las-certificaciones" class="section" data-cert-section>
    <div class="container">
      <h2>Todas las certificaciones</h2>
      <p class="section-subtitle">
        Cursos y certificaciones adicionales organizados por temática.
      </p>

      <!-- Barra de filtros -->
      <div class="filters" data-cert-filters>
        <button class="filter-btn is-active" type="button" data-filter="all">Todas</button>
        {certCategories.map((cat) => (
          <button class="filter-btn" type="button" data-filter={cat}>{cat}</button>
        ))}
      </div>

      <!-- Grid -->
      <div class="projects-grid" data-cert-grid>
        {otherCerts.map((c) => (
          <div class="project-card" data-category={c.data.category}>
            {c.data.credentialUrl && (
              <a
                class="card-link"
                href={c.data.credentialUrl}
                target="_blank"
                rel="noreferrer"
                aria-label="Ver certificado"
              ></a>
            )}

            <div class="cert-label">Certificado</div>
            <div class="card-category">{c.data.category}</div>

            <h3>{c.data.title}</h3>
            <p>{c.data.issuer} • {c.data.date}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Script PRO (public/scripts) -->
    <script type="module" src="/scripts/cert-filters.js"></script>
  </section>

  <!-- ================= CONTACTO ================= -->

<section id="contacto" class="section section-variant">
  <div class="container">
    <h2>Contacto</h2>
    <p class="section-subtitle">
      ¿Tenés una idea, proyecto o posición abierta? Estoy disponible para colaborar en desarrollo de software,
      automatización o infraestructura.
    </p>

    <div class="contact-wrap">
      <!-- LEFT: CTA -->
      <div class="contact-cta">
        <div class="contact-cta-top">
          <h3>Hablemos</h3>
          <span class="availability" title="Disponibilidad actual">
            <span class="dot"></span> Disponible para oportunidades
          </span>
        </div>

        <p class="contact-text">
          Respond(o) rápido por email o LinkedIn. Si querés, puedo compartir más detalles técnicos,
          capturas y referencias de proyectos.
        </p>

        <div class="contact-actions">
          <a class="btn primary" href="mailto:miraglioluis1@gmail.com">
            <!-- Mail icon -->
            <svg class="btn-ic" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 4.2-8 5.2-8-5.2V6l8 5.2L20 6v2.2Z"/>
            </svg>
            Enviar email
          </a>

          <a class="btn ghost" href="https://www.linkedin.com/in/luis-miraglio" target="_blank" rel="noreferrer">
            <!-- LinkedIn icon -->
            <svg class="btn-ic" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M20.45 20.45h-3.55v-5.56c0-1.33-.03-3.04-1.86-3.04-1.86 0-2.14 1.45-2.14 2.95v5.65H9.35V9h3.41v1.56h.05c.48-.9 1.65-1.86 3.39-1.86 3.63 0 4.3 2.39 4.3 5.5v6.25ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45Z"/>
            </svg>
            LinkedIn
          </a>
        </div>

        <p class="contact-footnote">
          Tip: también puedo enviar CV en PDF y referencias de proyectos a pedido.
        </p>
      </div>

      <!-- RIGHT: INFO -->
      <div class="contact-info" aria-label="Información de contacto">
        <a class="info-row" href="mailto:miraglioluis1@gmail.com">
          <div class="info-ic" aria-hidden="true">
            <!-- Mail -->
            <svg viewBox="0 0 24 24">
              <path fill="currentColor" d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 4.2-8 5.2-8-5.2V6l8 5.2L20 6v2.2Z"/>
            </svg>
          </div>
          <div class="info-text">
            <div class="info-label">Email</div>
            <div class="info-value">miraglioluis1@gmail.com</div>
          </div>
        </a>

        <div class="info-row" role="group" aria-label="Ubicación">
          <div class="info-ic" aria-hidden="true">
            <!-- Map pin -->
            <svg viewBox="0 0 24 24">
              <path fill="currentColor" d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7Zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5Z"/>
            </svg>
          </div>
          <div class="info-text">
            <div class="info-label">Ubicación</div>
            <div class="info-value">Sunchales, Santa Fe, Argentina</div>
          </div>
        </div>

        <a class="info-row" href="https://github.com/LuisMiraglio" target="_blank" rel="noreferrer">
          <div class="info-ic" aria-hidden="true">
            <!-- GitHub -->
            <svg viewBox="0 0 24 24">
              <path fill="currentColor" d="M12 .5C5.73.5.75 5.67.75 12.1c0 5.14 3.28 9.5 7.83 11.04.57.11.78-.25.78-.56v-2.04c-3.19.71-3.86-1.58-3.86-1.58-.52-1.36-1.27-1.72-1.27-1.72-1.04-.73.08-.72.08-.72 1.15.08 1.75 1.2 1.75 1.2 1.02 1.78 2.67 1.26 3.32.96.1-.76.4-1.26.73-1.55-2.55-.3-5.23-1.31-5.23-5.84 0-1.29.44-2.35 1.17-3.18-.12-.3-.51-1.52.11-3.17 0 0 .96-.32 3.14 1.21.91-.26 1.88-.39 2.85-.39.97 0 1.95.13 2.85.39 2.18-1.53 3.14-1.21 3.14-1.21.62 1.65.23 2.87.11 3.17.73.83 1.17 1.89 1.17 3.18 0 4.54-2.68 5.54-5.24 5.83.41.36.78 1.08.78 2.18v3.24c0 .31.21.67.79.56 4.55-1.54 7.82-5.9 7.82-11.04C23.25 5.67 18.27.5 12 .5z"/>
            </svg>
          </div>
          <div class="info-text">
            <div class="info-label">GitHub</div>
            <div class="info-value">github.com/LuisMiraglio</div>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>


<footer class="site-footer">
  <div class="container footer-inner">
    <p>© {new Date().getFullYear()} Luis Miraglio. Construido con Astro.</p>
    <div class="footer-links">
      <a href="#proyectos">Proyectos</a>
      <a href="#contacto">Contacto</a>
      <a href="mailto:miraglioluis1@gmail.com">Email</a>
    </div>
  </div>
</footer>

</BaseLayout>